@@ -0,0 +1,12 @@
+#!/bin/bash
+
+set -x
+
+git format-patch -p1
+
+mkdir -p /rockchip/aiot-3588a.git/radxa-uboot
+
+cp -a 0001-adapt-for-aiot-rk3588a.patch /rockchip/aiot-3588a.git/radxa-uboot
+
+echo "All done!"
+
