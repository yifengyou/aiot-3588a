diff --git a/kdev-build.sh b/kdev-build.sh
new file mode 100755
index 00000000000..e396d1eed01
--- /dev/null
+++ b/kdev-build.sh
@@ -0,0 +1,17 @@
+#!/bin/bash
+#
+
+set -xe
+
+tool=$(which aarch64-linux-gnu-gcc)
+export CROSS_COMPILE_ARM64="${tool%gcc}"
+echo "using gcc: [${CROSS_COMPILE_ARM64}]"
+
+rm -rf spl/u-boot-spl*
+make CROSS_COMPILE=${CROSS_COMPILE_ARM64} aiot3588a_defconfig
+#make CROSS_COMPILE=${CROSS_COMPILE_ARM64} -j$(nproc)
+./make.sh rk3588
+dtc -I dtb -O dts u-boot.dtb -o u-boot.dts
+
+ls -alh uboot.img
+
